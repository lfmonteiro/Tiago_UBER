# =============================================
# CONFIGURAÇÕES DO SERVIDOR
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# BANCO DE DADOS (MongoDB Atlas - gratuito)
# Crie em: https://cloud.mongodb.com
# =============================================
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster0.xxxxx.mongodb.net/agendamento?retryWrites=true&w=majority

# =============================================
# EVOLUTION API (WhatsApp)
# Instale em: https://evolution-api.com
# Ou use uma instância pronta em Railway/Render
# =============================================
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# =============================================
# E-MAIL (Gmail com App Password)
# Ative em: myaccount.google.com > Segurança > Senhas de app
# =============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="Agendamentos 🚗 <seuemail@gmail.com>"

# =============================================
# URL DO FRONTEND (após deploy no Netlify)
# =============================================
FRONTEND_URL=https://seu-app.netlify.app

# =============================================
# URL DO BACKEND (após deploy no Render)
# =============================================
BACKEND_URL=https://uber-agendamento.onrender.com
